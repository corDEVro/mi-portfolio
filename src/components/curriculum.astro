---
// Curriculum.astro
const personalData = {
    name: "Juan Manuel Cordero Ganfornina",
    title: "Desarrollador Web | Especialista en Automatización & Control",
    contact: {
        phone: "+34 693 602 738", // [cite: 2, 52]
        email: "jm.corderoganfornina@gmail.com", // [cite: 2, 53]
        location: "Chiclana de la Frontera, España", // [cite: 2]
        linkedin: "https://www.linkedin.com/in/juan-manuel-cor-gan", // [cite: 2, 54]
    },
    profile:
        "Desarrollador Web en formación (CFGS DAW) con más de 10 años de experiencia técnica en programación industrial y automatización[cite: 77, 79]. Experto en lógica de control y resolución de problemas, enfocado en crear soluciones digitales eficientes y escalables[cite: 78, 79].",
};

const projects = [
    {
        title: "Portal Inmobiliario (Freelance)",
        tech: "HTML5, CSS3, Bootstrap, JavaScript, PHP, MySQL",
        description:
            "Desarrollo integral de una plataforma para gestión de propiedades con sistema de filtrado dinámico y panel de administración CRUD.",
    },
];

const skills = {
    frontend: ["JavaScript (ES6+)", "HTML5", "CSS3", "Bootstrap", "Angular"], // [cite: 70, 71, 74, 95]
    backend: ["PHP", "Java", "Python", "MySQL", "Node.js"], // [cite: 68, 69, 95]
    industrial: ["PLCs & HMIs", "SCADA", "EPLAN", "Redes Industriales"], // [cite: 10, 100]
};

const education = [
    {
        degree: "CFGS en Desarrollo de Aplicaciones Web",
        institution: "ILERNA Online",
        date: "2024 – Presente", // [cite: 42, 44, 92]
        description:
            "Especialización en front-end, back-end y gestión de bases de datos[cite: 94].",
    },
    {
        degree: "CFGS en Automatización y Robótica Industrial",
        institution: "Salesiano Manuel Lora Tamayo",
        date: "2015 – 2017", // [cite: 45, 46, 99]
    },
];

const experience = [
    {
        role: "Delineante de Electricidad & Control",
        company: "Dragados Offshore",
        date: "2025 – Actualidad", // [cite: 24, 83]
        description:
            "Diseño de sistemas de control e instrumentación para plataformas de energía eólica marina[cite: 25, 84].",
    },
    {
        role: "Técnico Superior en Automatización",
        company: "Korus Suministros Eléctricos",
        date: "2017 – 2025", // [cite: 29, 87]
        description:
            "Liderazgo de proyectos 'Llave en Mano', desde el diseño de esquemas hasta la programación y puesta en marcha[cite: 88, 89].",
    },
];
---

<section class="cv-container">
    <header>
        <h1>{personalData.name}</h1>
        <p class="subtitle">{personalData.title}</p>
        <div class="contact-info">
            <span>{personalData.contact.location}</span> |
            <a href={`mailto:${personalData.contact.email}`}
                >{personalData.contact.email}</a
            > |
            <a href={personalData.contact.linkedin} target="_blank">LinkedIn</a>
        </div>
    </header>

    <hr />

    <section class="profile">
        <h2>Perfil Profesional</h2>
        <p>{personalData.profile}</p>
    </section>

    <section class="projects">
        <h2>Proyectos Destacados</h2>
        {
            projects.map((project) => (
                <div class="item">
                    <h3>{project.title}</h3>
                    <p>
                        <strong>Stack:</strong> {project.tech}
                    </p>
                    <p>{project.description}</p>
                </div>
            ))
        }
    </section>

    <section class="skills">
        <h2>Stack Tecnológico</h2>
        <div class="skills-grid">
            <div>
                <h4>Frontend</h4>
                <ul>{skills.frontend.map((s) => <li>{s}</li>)}</ul>
            </div>
            <div>
                <h4>Backend</h4>
                <ul>{skills.backend.map((s) => <li>{s}</li>)}</ul>
            </div>
            <div>
                <h4>Industrial & Tooling</h4>
                <ul>{skills.industrial.map((s) => <li>{s}</li>)}</ul>
            </div>
        </div>
    </section>

    <section class="experience">
        <h2>Experiencia Relevante</h2>
        {
            experience.map((exp) => (
                <div class="item">
                    <div class="header-row">
                        <strong>{exp.role}</strong>
                        <span>{exp.date}</span>
                    </div>
                    <p>
                        <em>{exp.company}</em>
                    </p>
                    <p>{exp.description}</p>
                </div>
            ))
        }
    </section>

    <section class="education">
        <h2>Formación</h2>
        {
            education.map((edu) => (
                <div class="item">
                    <div class="header-row">
                        <strong>{edu.degree}</strong>
                        <span>{edu.date}</span>
                    </div>
                    <p>{edu.institution}</p>
                </div>
            ))
        }
    </section>
</section>

