---

---

<section id="home" class="min-h-[80vh] flex items-center justify-center py-20">
  <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
    <div class="relative">
      <div class="absolute -inset-4 bg-brand-accent/20 rounded-full blur-2xl">
      </div>

      <div
        class="relative w-48 h-48 md:w-64 md:h-64 rounded-full border-4 border-brand-primary overflow-hidden shadow-2xl"
      >
        <img
          src="https://placedog.net/500/500"
          alt="Foto de JuanMa CorDEVro"
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <div class="text-center md:text-left space-y-6 max-w-lg">
      <div class="space-y-2">
        <p
          class="text-brand-primary font-mono font-bold tracking-widest uppercase text-sm"
        >
          Bienvenido a mi portfolio
        </p>
        <h1
          class="text-5xl md:text-7xl font-black text-brand-dark leading-tight"
        >
          JuanMa <span class="text-brand-secondary">CorDEVro</span>
        </h1>
        <h2 class="text-2xl md:text-3xl font-medium text-brand-primary/80">
          Desarrollador Web Trainee
        </h2>
      </div>

      <p class="text-lg text-brand-dark/80 leading-relaxed">
        Transformando ideas en código real. Especializado en crear experiencias
        web modernas, limpias y funcionales mientras sigo explorando las
        profundidades del desarrollo.
      </p>

      <div
        class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start pt-4"
      >
        <a
          href="./curriculum.astro"
          download
          class="bg-brand-dark text-brand-light px-8 py-3 rounded-full font-bold hover:bg-brand-primary transition-all shadow-lg hover:-translate-y-1 flex items-center justify-center gap-2"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v4"></path><polyline
              points="7 10 12 15 17 10"></polyline><line
              x1="12"
              y1="15"
              x2="12"
              y2="3"></line></svg
          >
          Mi CV
        </a>
      </div>
    </div>
  </div>
</section>
