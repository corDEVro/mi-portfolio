<section id="contact" class="py-24 scroll-mt-20">
  <div
    class="max-w-3xl mx-auto bg-white p-8 md:p-12 rounded-3xl shadow-xl border border-brand-primary/10"
  >
    <h2 class="text-4xl font-black text-brand-dark mb-6 text-center">
      ¿Hablamos?
    </h2>
    <form
      action="contacto-portfolio"
      method="POST"
      data-netlify="true"
      class="space-y-4"
    >
      <div class="grid md:grid-cols-2 gap-4">
        <input
          type="text"
          name="name"
          placeholder="Tu nombre"
          class="w-full px-5 py-3 rounded-xl bg-brand-light/30 border border-brand-primary/20 focus:border-brand-accent outline-none"
          required
        />
        <input
          type="email"
          name="email"
          placeholder="Tu email"
          class="w-full px-5 py-3 rounded-xl bg-brand-light/30 border border-brand-primary/20 focus:border-brand-accent outline-none"
          required
        />
      </div>
      <textarea
        name="message"
        rows="4"
        placeholder="¿En qué puedo ayudarte?"
        class="w-full px-5 py-3 rounded-xl bg-brand-light/30 border border-brand-primary/20 focus:border-brand-accent outline-none"
        required></textarea>
      <button
        type="submit"
        class="w-full bg-brand-dark text-brand-light font-bold py-4 rounded-xl hover:bg-brand-primary transition-all shadow-lg"
      >
        Enviar Mensaje
      </button>
    </form>
  </div>
</section>
