---
interface Props {
  title: string;
  desc: string;
  tags: string[];
  index: number;
}

const { title, desc, tags, index } = Astro.props;
---

<div
  class="project-card absolute transition-all duration-500 ease-in-out opacity-0 pointer-events-none"
  data-index={index}
>
  <div
    class="bg-white rounded-4xl overflow-hidden shadow-lg border-4 border-transparent flex flex-col w-75 md:w-100"
  >
    <div
      class="aspect-video bg-brand-primary/10 flex items-center justify-center"
    >
      <span class="text-brand-primary/20 font-black text-4xl italic">CODE</span>
    </div>
    <div class="p-8">
      <h3 class="text-2xl font-bold text-brand-dark mb-2">{title}</h3>
      <p class="text-brand-dark/70 text-sm mb-4 leading-relaxed">{desc}</p>
      <div class="flex flex-wrap gap-2">
        {
          tags.map((tag) => (
            <span class="text-[10px] uppercase font-bold bg-brand-light text-brand-primary px-3 py-1 rounded-full">
              {tag}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</div>
