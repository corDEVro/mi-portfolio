---
import BaseLayout from "../layouts/BaseLayout.astro";

const personalData = {
    name: "Juan Manuel Cordero Ganfornina",
    title: "Desarrollador Web | Especialista en Automatización & Control",
    profile:
        "Desarrollador Web en formación (CFGS DAW) con más de 10 años de experiencia técnica en programación industrial y automatización. Experto en lógica de control y resolución de problemas, enfocado en crear soluciones digitales eficientes.",
    contact: {
        email: "jm.corderoganfornina@gmail.com",
        location: "Chiclana de la Frontera, España",
        linkedin: "https://www.linkedin.com/in/juan-manuel-cor-gan",
    },
};

const projects = [
    {
        title: "Portal Inmobiliario (Freelance)",
        tech: "HTML5, CSS3, Bootstrap, JavaScript, PHP, MySQL",
        description:
            "Desarrollo integral de una plataforma para gestión de propiedades con sistema de filtrado dinámico y panel de administración CRUD.",
    },
];

const skills = {
    frontend: ["JavaScript (ES6+)", "HTML5", "CSS3", "Bootstrap", "AstroJS"],
    backend: ["PHP", "Java", "Python", "MySQL"],
    industrial: ["Programación PLCs", "HMIs", "EPLAN", "Redes Industriales"],
};

const experience = [
    {
        role: "Delineante de Electricidad & Control",
        company: "Dragados Offshore",
        date: "2025 – Actualidad",
        description:
            "Diseño de sistemas de control e instrumentación para plataformas de energía eólica marina.",
    },
    {
        role: "Técnico Superior en Automatización",
        company: "Korus Suministros Eléctricos",
        date: "2017 – 2025",
        description:
            "Planificación y ejecución de proyectos 'Llave en Mano', desde el diseño hasta la puesta en marcha.",
    },
];
---

<BaseLayout title="JuanMa CorDEVro | CV" showNav={false}>
    <main class="max-w-4xl mx-auto px-6 py-12">
        <div class="mb-8">
            <a
                href="/"
                class="text-brand-primary hover:text-brand-secondary flex items-center gap-2 font-mono text-sm"
            >
                <span>←</span> VOLVER AL PORTFOLIO
            </a>
        </div>

        <section class="reveal active space-y-12">
            <header class="text-center space-y-4">
                <h1
                    class="text-4xl md:text-5xl font-black text-brand-dark dark:text-brand-accent"
                >
                    {personalData.name}
                </h1>
                <p class="text-xl font-bold text-brand-primary italic">
                    {personalData.title}
                </p>
                <div
                    class="flex flex-wrap justify-center gap-4 text-sm opacity-80"
                >
                    <span>{personalData.contact.location}</span>
                    <span>•</span>
                    <a
                        href={`mailto:${personalData.contact.email}`}
                        class="hover:text-brand-secondary underline"
                        >{personalData.contact.email}</a
                    >
                    <span>•</span>
                    <a
                        href={personalData.contact.linkedin}
                        target="_blank"
                        class="hover:text-brand-secondary underline">LinkedIn</a
                    >
                </div>
            </header>

            <section>
                <h2
                    class="text-2xl font-bold text-brand-dark dark:text-brand-secondary border-b-2 border-brand-accent/30 mb-4"
                >
                    Perfil Profesional
                </h2>
                <p class="leading-relaxed">{personalData.profile}</p>
            </section>

            <section>
                <h2
                    class="text-2xl font-bold text-brand-dark dark:text-brand-secondary border-b-2 border-brand-accent/30 mb-6"
                >
                    Proyectos Destacados
                </h2>
                {
                    projects.map((project) => (
                        <div class="bg-brand-primary/5 dark:bg-brand-dark/20 p-6 rounded-xl border-l-4 border-brand-accent">
                            <h3 class="text-xl font-bold text-brand-primary">
                                {project.title}
                            </h3>
                            <p class="text-sm font-mono mt-1 opacity-70 italic">
                                {project.tech}
                            </p>
                            <p class="mt-3">{project.description}</p>
                        </div>
                    ))
                }
            </section>

            <section>
                <h2
                    class="text-2xl font-bold text-brand-dark dark:text-brand-secondary border-b-2 border-brand-accent/30 mb-6"
                >
                    Stack Tecnológico
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div class="space-y-3">
                        <h4
                            class="font-black text-brand-primary uppercase text-sm tracking-widest"
                        >
                            Frontend
                        </h4>
                        <ul class="space-y-1">
                            {
                                skills.frontend.map((s) => (
                                    <li class="flex items-center gap-2">
                                        <span class="text-brand-accent">▹</span>{" "}
                                        {s}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                    <div class="space-y-3">
                        <h4
                            class="font-black text-brand-primary uppercase text-sm tracking-widest"
                        >
                            Backend
                        </h4>
                        <ul class="space-y-1">
                            {
                                skills.backend.map((s) => (
                                    <li class="flex items-center gap-2">
                                        <span class="text-brand-accent">▹</span>{" "}
                                        {s}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                    <div class="space-y-3">
                        <h4
                            class="font-black text-brand-primary uppercase text-sm tracking-widest"
                        >
                            Industrial
                        </h4>
                        <ul class="space-y-1">
                            {
                                skills.industrial.map((s) => (
                                    <li class="flex items-center gap-2">
                                        <span class="text-brand-accent">▹</span>{" "}
                                        {s}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>
            </section>

            <section>
                <h2
                    class="text-2xl font-bold text-brand-dark dark:text-brand-secondary border-b-2 border-brand-accent/30 mb-6"
                >
                    Experiencia Relevante
                </h2>
                <div class="space-y-8">
                    {
                        experience.map((exp) => (
                            <div class="relative pl-6 border-l-2 border-brand-primary/30">
                                <div class="absolute -left-2.25 top-0 w-4 h-4 rounded-full bg-brand-primary" />
                                <div class="flex flex-col md:flex-row md:justify-between md:items-center">
                                    <h3 class="text-lg font-bold text-brand-dark dark:text-brand-light">
                                        {exp.role}
                                    </h3>
                                    <span class="text-sm font-mono text-brand-primary font-bold">
                                        {exp.date}
                                    </span>
                                </div>
                                <p class="text-brand-secondary font-medium">
                                    {exp.company}
                                </p>
                                <p class="mt-2 opacity-90">{exp.description}</p>
                            </div>
                        ))
                    }
                </div>
            </section>
        </section>
    </main>
</BaseLayout>
